# ── Build artifacts ────────────────────────────────────────────────────────────
.next
out
dist
build

# ── Dependencies (installed inside the container, not copied) ──────────────────
node_modules

# ── Git ────────────────────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ── Environment (injected via env_file, never baked into image) ───────────────
.env
.env.*
!.env.example

# ── Dev / IDE ─────────────────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Test artifacts ─────────────────────────────────────────────────────────────
test-results
playwright-report
coverage

# ── Docs / scripts (not needed inside container) ──────────────────────────────
*.md
scripts/
supabase/
scratch/
screenshots/
tests/

# ── Docker files themselves ────────────────────────────────────────────────────
Dockerfile*
docker-compose*
Caddyfile

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
