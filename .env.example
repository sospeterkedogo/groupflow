# Supabase Project Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=https://espeezy.com

# Google OAuth Application Keys (Configure in Supabase Dashboard)
# These are for your reference; Supabase handles the actual exchange.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth Application Keys (For login and API access)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# The Secret string you configure in your GitHub Webhook settings 
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SUBSCRIPTION_ID=price_...
STRIPE_PRICE_ONE_TIME_ID=price_...
STRIPE_SUCCESS_URL=https://espeezy.com/dashboard/settings?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://espeezy.com/dashboard/settings

TWILIORECOVERYCODE=VD4VABS9LN3N5NF6WM16MXSE

# AI Agent Orchestration
# Secret key used by automated agent workers to authenticate against the agent task API.
# Set to a long random string (e.g. openssl rand -hex 32). Keep this private.
AGENT_API_KEY=your-agent-api-key-here
